\\percent of each student\\

#include <stdio.h>

int main() {
    int i, j, sum;
    float percent[5];
    int marks[5][4];

    for (i = 0; i < 5; i++) {
        printf("\nEnter marks of student %d:\n", i + 1);
        for (j = 0; j < 4; j++) {
            printf("  Subject %d: ", j + 1);
            scanf("%d", &marks[i][j]);
        }
    }

    for (i = 0; i < 5; i++) {
        sum = 0;
        for (j = 0; j < 4; j++) {
            sum = sum + marks[i][j];
        }
        percent[i] = sum / 4.0;
        printf("Student %d percentage: %.2f%%\n", i + 1, percent[i]);
    }

    return 0;
}


